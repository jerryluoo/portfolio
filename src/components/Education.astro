---
const education = [
  {
    school: 'University of British Columbia',
    degree: 'Bachelor of Commerce, Combined Major in Business and Computer Science',
    period: '2026 – 2030',
    details: [
      'Combined Major in Business and Computer Science',
      'Relevant coursework: Data Structures, Algorithms, Software Engineering, Business Analytics',
    ],
  },
];
---

<section id="education" class="py-24 relative">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center gap-4 mb-16 animate-on-scroll">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white">
        Education
      </h2>
      <div class="h-px flex-1 bg-gradient-to-r from-primary/30 to-transparent"></div>
    </div>

    <div class="space-y-6">
      {education.map((edu, i) => (
        <div class="group relative animate-on-scroll" style={`transition-delay: ${i * 100}ms`}>
          <div class="absolute -inset-x-4 -inset-y-2 rounded-2xl bg-gradient-to-r from-accent/5 to-primary/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" aria-hidden="true"></div>
          <div class="relative glass rounded-2xl p-6 sm:p-8 hover:glow transition-all duration-300">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-4">
              <div>
                <h3 class="text-xl font-semibold text-gray-900 dark:text-white">
                  {edu.degree}
                </h3>
                <p class="text-accent dark:text-accent-light font-medium mt-1">{edu.school}</p>
              </div>
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-accent/10 dark:bg-accent/20 text-accent dark:text-accent-light whitespace-nowrap">
                {edu.period}
              </span>
            </div>
            <ul class="space-y-3 mt-4">
              {edu.details.map((item) => (
                <li class="flex items-start gap-3 text-gray-600 dark:text-gray-400">
                  <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.62 48.62 0 0112 20.904a48.62 48.62 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
