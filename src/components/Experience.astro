---
const experiences = [
  {
    company: 'Company Name',
    role: 'Software Engineer',
    period: 'Jan 2024 – Present',
    description: [
      'Built and maintained full-stack web applications serving thousands of users',
      'Collaborated with cross-functional teams to define and ship new features',
      'Improved application performance by optimizing database queries and caching strategies',
    ],
  },
  {
    company: 'Previous Company',
    role: 'Software Engineering Intern',
    period: 'Jun 2023 – Dec 2023',
    description: [
      'Developed RESTful APIs and integrated third-party services',
      'Wrote comprehensive unit and integration tests, achieving 90%+ code coverage',
      'Participated in code reviews and contributed to engineering documentation',
    ],
  },
];
---

<section id="experience" class="py-24 relative">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center gap-4 mb-16 animate-on-scroll">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white">
        Experience
      </h2>
      <div class="h-px flex-1 bg-gradient-to-r from-primary/30 to-transparent"></div>
    </div>

    <div class="space-y-6">
      {experiences.map((exp, i) => (
        <div class="group relative animate-on-scroll" style={`transition-delay: ${i * 100}ms`}>
          <div class="absolute -inset-x-4 -inset-y-2 rounded-2xl bg-gradient-to-r from-primary/5 to-accent/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500" aria-hidden="true"></div>
          <div class="relative glass rounded-2xl p-6 sm:p-8 hover:glow transition-all duration-300">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-4">
              <div>
                <h3 class="text-xl font-semibold text-gray-900 dark:text-white">
                  {exp.role}
                </h3>
                <p class="text-primary dark:text-primary-light font-medium mt-1">{exp.company}</p>
              </div>
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-primary/10 dark:bg-primary/20 text-primary dark:text-primary-light whitespace-nowrap">
                {exp.period}
              </span>
            </div>
            <ul class="space-y-3 mt-4">
              {exp.description.map((item) => (
                <li class="flex items-start gap-3 text-gray-600 dark:text-gray-400">
                  <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
