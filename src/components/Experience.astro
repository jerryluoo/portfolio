---
const experiences = [
  {
    company: 'Company Name',
    role: 'Software Engineer',
    period: 'Jan 2024 – Present',
    description: [
      'Built and maintained full-stack web applications serving thousands of users',
      'Collaborated with cross-functional teams to define and ship new features',
      'Improved application performance by optimizing database queries and caching strategies',
    ],
  },
  {
    company: 'Previous Company',
    role: 'Software Engineering Intern',
    period: 'Jun 2023 – Dec 2023',
    description: [
      'Developed RESTful APIs and integrated third-party services',
      'Wrote comprehensive unit and integration tests, achieving 90%+ code coverage',
      'Participated in code reviews and contributed to engineering documentation',
    ],
  },
];
---

<section id="experience" class="py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-12 animate-on-scroll">
      Experience
    </h2>
    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-0 md:left-8 top-0 bottom-0 w-px bg-gray-200 dark:bg-gray-800" aria-hidden="true"></div>

      <div class="space-y-12">
        {experiences.map((exp) => (
          <div class="relative pl-8 md:pl-20 animate-on-scroll">
            <!-- Timeline dot -->
            <div class="absolute left-0 md:left-8 top-1.5 -translate-x-1/2 w-3 h-3 rounded-full bg-primary border-2 border-white dark:border-gray-950" aria-hidden="true"></div>

            <div class="bg-gray-50 dark:bg-gray-900 rounded-xl p-6 border border-gray-100 dark:border-gray-800">
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-2">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
                  {exp.role}
                </h3>
                <span class="text-sm text-gray-500 dark:text-gray-400 mt-1 sm:mt-0">
                  {exp.period}
                </span>
              </div>
              <p class="text-primary font-medium text-sm mb-3">{exp.company}</p>
              <ul class="space-y-2">
                {exp.description.map((item) => (
                  <li class="text-gray-600 dark:text-gray-400 text-sm flex items-start gap-2">
                    <span class="text-primary mt-1.5 flex-shrink-0" aria-hidden="true">▸</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
