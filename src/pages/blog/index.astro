---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);
---

<BaseLayout title="Blog | Jerry Luo" description="Thoughts on web development, software engineering, and things I'm learning.">
  <Header />
  <main class="pt-24 pb-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">Blog</h1>
      <p class="text-gray-600 dark:text-gray-400 mb-12">
        Thoughts on web development, software engineering, and things I'm learning.
      </p>

      {posts.length === 0 && (
        <p class="text-gray-500 dark:text-gray-400">No posts yet. Check back soon!</p>
      )}

      <div class="space-y-8">
        {posts.map((post) => (
          <article class="group">
            <a href={`${import.meta.env.BASE_URL}blog/${post.id}/`} class="block p-6 -mx-6 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors">
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-2">
                <h2 class="text-xl font-semibold text-gray-900 dark:text-white group-hover:text-primary transition-colors">
                  {post.data.title}
                </h2>
                <time datetime={post.data.pubDate.toISOString()} class="text-sm text-gray-500 dark:text-gray-400 mt-1 sm:mt-0">
                  {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              </div>
              <p class="text-gray-600 dark:text-gray-400 mb-3">{post.data.description}</p>
              {post.data.tags && (
                <div class="flex flex-wrap gap-2">
                  {post.data.tags.map((tag) => (
                    <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </a>
          </article>
        ))}
      </div>

      <div class="mt-12">
        <a href={import.meta.env.BASE_URL} class="text-primary hover:underline font-medium">&larr; Back to portfolio</a>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
